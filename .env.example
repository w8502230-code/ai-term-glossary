# 复制为 .env 后填写；勿将 .env 提交到 Git。
# 后端本地 / Railway 使用下列变量（不含 VITE_*）。

LLM_PROVIDER=bailian
BAILIAN_API_KEY=
BAILIAN_MODEL=qwen-turbo-latest
# BAILIAN_BASE_URL=
# BAILIAN_JSON_OBJECT=
# ZHIPU_API_KEY=
# ZHIPU_MODEL=glm-4-flash
# HTTPS_PROXY=http://127.0.0.1:7890

PORT=3001
# DEFINE_GLOBAL_RPM=60
# STATS_STORE_PATH=

# 生产环境：英文逗号分隔的允许来源（Cloudflare Pages 地址），勿带尾斜杠。
# 示例：https://ai-term-glossary.pages.dev
# 不设则开发时等价于允许任意来源（origin: true），便于本地联调。
# CORS_ORIGINS=
#
# 与 CORS_ORIGINS 同时使用时：允许所有 https://*.你的项目.pages.dev 预览域名（hash 子域每次部署可能变）。
# 只填主机名，不要 https://。示例：ai-term-glossary.pages.dev
# CORS_PAGES_PROJECT_HOST=

# 以下仅用于在「本机」构建前端生产包时指向 Railway；Cloudflare Pages 上在控制台配置同名变量即可，不必写进本文件。
# VITE_API_BASE_URL=https://xxxx.up.railway.app
